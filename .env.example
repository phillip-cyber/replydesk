# Required: your Anthropic API key (used by /api/preview and /api/chat)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: model to use for AI rebuild + admin chat (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required for Google sign-in (NextAuth)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-secret
NEXTAUTH_SECRET=run-`openssl rand -base64 32`-and-paste-here
NEXTAUTH_URL=https://bloom-psi-jet.vercel.app

# Required for Stripe Checkout ($10 unlock)
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_PRICE_ID=price_xxx
